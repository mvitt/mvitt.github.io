<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
             xmlns:tools="http://schemas.android.com/tools"
             android:layout_width="match_parent"
             android:layout_height="match_parent"
              android:orientation="vertical"
              android:paddingBottom="16dp"
              android:paddingLeft="64dp"
              android:paddingRight="64dp"
              android:paddingTop="16dp"
             tools:context="com.android.lewis.vitt.matthew.caloriequickcount.FoodDetailFragment">

    <EditText
        android:id="@+id/foodDetailFoodName"
        android:hint="@string/food_detail_enter_food_name_hint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp"/>

    <EditText
        android:id="@+id/foodDetailCalories"
        android:hint="@string/food_detail_enter_calories_hint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:inputType="number"
        android:layout_marginBottom="10dp"/>

    <Button
        android:id="@+id/submitFoodBtn"
        android:layout_gravity="center_horizontal"
        android:text="@string/submit_food_btn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

</LinearLayout>
